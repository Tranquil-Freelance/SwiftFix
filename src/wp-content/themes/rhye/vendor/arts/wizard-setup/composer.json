{
  "name": "arts/wizard-setup",
  "description": "Theme onboarding based on MerlinWP by Rich Tabor",
  "type": "library",
  "minimum-stability": "dev",
  "repositories": [
    {
      "type": "path",
      "url": "/Users/art/Projects/Framework/packages/ArtsMerlin",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "/Users/art/Projects/Framework/packages/ArtsUtilities",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "/Users/art/Projects/Framework/packages/ArtsContentImporter",
      "options": {
        "symlink": true
      }
    }
  ],
  "autoload": {
    "psr-4": {
      "Arts\\WizardSetup\\": "src/"
    }
  },
  "authors": [
    {
      "name": "Artem Semkin",
      "email": "art.krsk@gmail.com"
    }
  ],
  "require": {
    "arts/merlin-wp": "@dev",
    "arts/utilities": "@dev"
  }
}
