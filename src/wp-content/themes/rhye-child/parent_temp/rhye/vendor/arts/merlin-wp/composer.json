{
  "name": "arts/merlin-wp",
  "description": "Better WordPress Theme Onboarding. Forked from Merlin WP by Rich Tabor.",
  "type": "library",
  "minimum-stability": "dev",
  "license": "GPL-3.0+",
  "repositories": [
    {
      "type": "path",
      "url": "/Users/art/Projects/Framework/packages/ArtsContentImporter",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "/Users/art/Projects/Framework/packages/ArtsUtilities",
      "options": {
        "symlink": true
      }
    }
  ],
  "authors": [
    {
      "name": "Artem Semkin",
      "homepage": "https://artemsemkin.com"
    },
    {
      "name": "Rich Tabor",
      "homepage": "https://richtabor.com"
    },
    {
      "name": "ProteusThemes",
      "homepage": "https://www.proteusthemes.com/"
    }
  ],
  "require": {
    "monolog/monolog": "^2.10",
    "arts/wp-content-importer-v2": "@dev",
    "arts/utilities": "@dev"
  },
  "autoload": {
    "psr-4": {
      "Arts\\Merlin\\": "src/php/"
    }
  }
}
